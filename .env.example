# Azure OpenAI ---------------------------------------------------------------
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_KEY=replace-me
AZURE_OPENAI_API_VERSION=2024-10-21

# Chat deployment (e.g. gpt-4o, gpt-4o-mini)
AZURE_OPENAI_CHAT_DEPLOYMENT=gpt-4o
AZURE_OPENAI_CHAT_MODEL=gpt-4o

# Embedding deployment (e.g. text-embedding-3-large, text-embedding-3-small)
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-large
AZURE_OPENAI_EMBEDDING_MODEL=text-embedding-3-large

# Paths ----------------------------------------------------------------------
DATA_DIR=./data/newsletters
STORAGE_DIR=./storage/chroma
COLLECTION_NAME=fabric_mastery

# Indexing -------------------------------------------------------------------
CHUNK_SIZE=1024
CHUNK_OVERLAP=128

# Retrieval & generation -----------------------------------------------------
TOP_K=6
SIMILARITY_CUTOFF=0.35
TEMPERATURE=0.1
MAX_TOKENS=1024

# UI -------------------------------------------------------------------------
DEFAULT_LANGUAGE=en
